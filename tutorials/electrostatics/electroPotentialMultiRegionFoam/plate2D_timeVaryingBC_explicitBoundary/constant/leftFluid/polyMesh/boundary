FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       polyBoundaryMesh;
    location    "constant/leftFluid/polyMesh";
    object      boundary;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

6
(
    back
    {
        type            empty;
        inGroups        1(empty);
        nFaces          50;
        startFace       85;
    }
    down
    {
        type            patch;
        nFaces          5;
        startFace       135;
    }
    up
    {
        type            patch;
        nFaces          5;
        startFace       140;
    }
    left
    {
        type            patch;
        nFaces          10;
        startFace       145;
    }
    front
    {
        type            empty;
        inGroups        1(empty);
        nFaces          50;
        startFace       155;
    }
    leftFluid_to_rightDielectric
    {
        type            mappedWall;
        inGroups        1(wall);
        nFaces          10;
        startFace       205;
        sampleMode      nearestPatchFace;
        sampleRegion    rightDielectric;
        samplePatch     rightDielectric_to_leftFluid;
    }
)

