FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
#include "../configuration/config"

solvers
{
    ePotential
    {
        solver          GAMG;
	    smoother 	    GaussSeidel;
        tolerance       1e-9;
        relTol          0;
        maxIter         2000;
    }
}

ePotentialControls
{
    nNonOrthogonalCorrectors    0;

    nonCoupledResidualControl
    {
        tolerance       1e-9;
        maxIter         200;
    }
}

