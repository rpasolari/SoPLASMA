FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      electromagneticsProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
#include "../../configuration/config"

electromagneticsModel   multiRegionPoisson;

multiRegionPoissonCoeffs
{
    dielectricConstant      $epsilonRleftGas;// Dimensionless

    EScheme                 reconstruct;     // Options: reconstruct | faceValue

    PoissonScheme           explicit;        // Here, the only option

    nNonOrthogonalCorrectors 0;              // Non-ortho correctors

    backgroundDensity       2.5e25;          // m^-3, for plasma applications

    rightDielectric
    {
        dielectricConstant      $epsilonRrightDielectric;
    }
}
