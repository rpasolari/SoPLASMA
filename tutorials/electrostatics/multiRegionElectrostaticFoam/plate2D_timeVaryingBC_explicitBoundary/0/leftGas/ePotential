FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0/leftGas";
    object      ePotential;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
#include        "../../configuration/config"

dimensions      [ 1 2 -3 0 0 -1 0 ];

internalField   uniform 0;

boundaryField
{
    back
    {
        type            empty;
    }
    down
    {
        type            zeroGradient;
        value           uniform 0;
    }
    up
    {
        type            zeroGradient;
        value           uniform 0;
    }
    left
    {
        type            uniformFixedValue;
        value           uniform 0;
        uniformValue    table ( ( 0 0 ) ( $endTime $dirichletValueLeft ) );
    }
    front
    {
        type            empty;
    }
    leftGas_to_rightDielectric
    {
        type            coupledElectricPotential;
        value           $internalField;
        surfCharge      $surfChargeDict;
        surfChargeNbr   none;
        useImplicit     $useImplicit;
    }
}


