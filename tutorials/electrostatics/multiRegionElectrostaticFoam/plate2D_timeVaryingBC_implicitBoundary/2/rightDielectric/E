FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volVectorField;
    location    "2/rightDielectric";
    object      E;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 1 -3 0 0 -1 0];

internalField   uniform (0 0 0);

boundaryField
{
    back
    {
        type            empty;
    }
    down
    {
        type            calculated;
        value           uniform (0 0 0);
    }
    up
    {
        type            calculated;
        value           uniform (0 0 0);
    }
    front
    {
        type            empty;
    }
    right
    {
        type            calculated;
        value           uniform (0 0 0);
    }
    rightDielectric_to_leftGas
    {
        type            calculated;
        value           uniform (0 0 0);
    }
}


