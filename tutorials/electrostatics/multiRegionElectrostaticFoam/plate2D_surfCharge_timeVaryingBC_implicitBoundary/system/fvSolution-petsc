FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
solvers
{
    ePotential
    {  
        solver petsc;
        implicitRegionCoupling true;

        petsc
        {
            options
            {
                ksp_type  cg;
                pc_type  hypre;
                mat_type  aij;
            }
        }

        // OpenFOAM-level tolerances
        tolerance   1e-9;
        relTol      0;
        maxIter     2000;
    }
}

