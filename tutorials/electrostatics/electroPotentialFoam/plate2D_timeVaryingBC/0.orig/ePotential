FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      ePotential;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
#include "../configuration/config"

dimensions      [1 2 -3 0 0 -1 0];

internalField   uniform 0;

boundaryField
{
    top
    {
        type            uniformFixedValue;
        uniformValue    table
        (
            (0    0)
            ($endTime    $dirichletValueTop)
        );
    }

    walls
    {
        type    fixedValue;
        value   uniform 0;
    }

    frontAndBack
    {
        type    empty;
    }
}

