FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      refineMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

set streamerRegion_refine_2;

coordinateSystem global;
globalCoeffs
{
    tan1         (1 0 0); // Radial direction (x)
    tan2      (0 1 0); // Axial direction (y)
}

directions      (tan1 tan2);

useHexTopology  yes;

geometricCut    false;

writeMesh       no;

applyMaxCellLimit no;


