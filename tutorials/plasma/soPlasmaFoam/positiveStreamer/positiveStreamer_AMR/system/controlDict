FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
#include "../configuration/config"

libs
(
    "libpetscFoam.so"
    "libROUNDSchemes.so"
    "libamrDynamicFvMesh.so"
    "libamrDynamicMesh.so"
    "libamrLoadPolicies.so"
    "libamrCPULoad.so"
    "libamrFunctionObjects.so"
    "libamrIndicators.so"
    "libamrLagrangian.so"
);

application     soPlasmaFoam;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         $endTime;

deltaT          $deltaT;

writeControl    $writeControl;

writeInterval   $writeInterval;

purgeWrite      0;

writeFormat     ascii;

writePrecision  12;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

