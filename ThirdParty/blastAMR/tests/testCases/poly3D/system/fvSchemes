FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //


ddtSchemes
{
    default         Euler;
}

d2dt2Schemes
{
    default         Euler;
}

interpolationSchemes
{
    default         linear;
}

divSchemes
{
    default         Gauss linear;
}

gradSchemes
{
    default         Gauss linear;
}

snGradSchemes
{
    default         corrected;
}

laplacianSchemes
{
    default         Gauss linear corrected;
}

fluxRequired
{
    default         no;
}


