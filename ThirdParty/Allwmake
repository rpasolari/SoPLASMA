#!/bin/bash
#---------------------------------------------
#  Allwmake script for foamPlasmaMultiRun suite
#  Builds all ThirdParty in ./ThirdParty
#---------------------------------------------

set -e

cd "${0%/*}" || exit 1

# Colors
GREEN='\033[1;32m'
RED='\033[1;31m'
NC='\033[0m'   # No Color

# Array to track failures
FAILED=()

echo ">>> Building petsc4Foam"
echo "----------------------------------------------"

if ./petsc4Foam/Allwmake -prefix=openfoam; then
    echo -e "${GREEN}>>> petsc4Foam built successfully${NC}"
else
    echo -e "${RED}>>> petsc4Foam build FAILED (ignored)${NC}"
    FAILED+=("petsc4Foam")
fi

echo ""

echo ">>> Building blastAMR"
echo "----------------------------------------------"

if ./blastAMR/Allwmake; then
    echo -e "${GREEN}>>> blastAMR built successfully${NC}"
else
    echo -e "${RED}>>> blastAMR build FAILED (ignored)${NC}"
    FAILED+=("blastAMR")
fi

echo ""

echo ">>> Building libROUNDSchemes"
echo "----------------------------------------------"

if ./libROUNDSchemes/Allwmake; then
    echo -e "${GREEN}>>> libROUNDSchemes built successfully${NC}"
else
    echo -e "${RED}>>> libROUNDSchemes build FAILED (ignored)${NC}"
    FAILED+=("libROUNDSchemes")
fi

echo ""

echo "----------------------------------------------"
echo ">>> Done building ThirdParty."
echo ""

# Summary
if [ ${#FAILED[@]} -eq 0 ]; then
    echo -e "${GREEN}>>> All ThirdParty components built successfully.${NC}"
else
    echo -e "${RED}>>> These ThirdParty components FAILED to build:${NC}"
    for item in "${FAILED[@]}"; do
        echo -e "    ${RED}- $item${NC}"
    done
fi
